{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "types": [
      "node",
      "@playwright/test"
    ],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "playwright.config.ts",
    "features/**/*.feature",
    "src/**/*.ts",
    "tests/**/*.ts"
  ]
}
